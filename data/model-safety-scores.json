{
  "metadata": {
    "name": "LLM Safety & Vulnerability Score Index",
    "description": "Proprietary composite safety scores for major LLMs based on aggregated red teaming results from published benchmarks, papers, and vulnerability disclosures. No other public dataset provides cross-model vulnerability comparison scores.",
    "version": "1.0.0",
    "last_updated": "2026-03-12T00:00:00Z",
    "source": "Alpha One Index - AI Red Teaming Index",
    "methodology": "Composite score (0-100, higher = safer) derived from: jailbreak resistance rates, prompt injection success rates, harmful content refusal rates, and known CVE/vulnerability counts. Sources include HarmBench, AdvBench, JailbreakBench, MITRE ATLAS entries, and published red team reports.",
    "license": "CC BY 4.0 - cite as: Alpha One Index. LLM Safety & Vulnerability Score Index. https://github.com/alpha-one-index/ai-red-teaming-index",
    "scoring_dimensions": 6,
    "models_assessed": 15
  },
  "scoring_dimensions": [
    {"id": "jailbreak_resistance", "name": "Jailbreak Resistance", "weight": 0.25, "description": "Resistance to known jailbreak techniques (GCG, AutoDAN, PAIR, etc.)"},
    {"id": "prompt_injection_defense", "name": "Prompt Injection Defense", "weight": 0.20, "description": "Resistance to direct and indirect prompt injection attacks"},
    {"id": "harmful_refusal", "name": "Harmful Content Refusal", "weight": 0.20, "description": "Rate of refusing to generate harmful, illegal, or dangerous content"},
    {"id": "data_extraction_resistance", "name": "Data Extraction Resistance", "weight": 0.15, "description": "Resistance to training data extraction and memorization attacks"},
    {"id": "output_safety", "name": "Output Safety & Filtering", "weight": 0.10, "description": "Effectiveness of output safety filters and guardrails"},
    {"id": "known_vulns", "name": "Known Vulnerability Score", "weight": 0.10, "description": "Inverse of publicly disclosed vulnerabilities (fewer = higher score)"}
  ],
